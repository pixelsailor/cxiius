# Copy to `.env` / `.dev.vars` for local Worker preview (`npm run preview`) or `wrangler dev`.
# Replace KV namespace IDs in wrangler.jsonc with IDs from `wrangler kv namespace create`.

# Anthropic Messages API (server-only; never expose to client).
ANTHROPIC_API_KEY=

# Set to 1 with ANTHROPIC_API_KEY to run real API tests: npm run test:ai-live
# Omit in CI to avoid spending quota (live specs skip when unset).
RUN_AI_LIVE=

# Salt for hashing client identifiers in KV rate-limit keys (ADR-010). Use a long random string.
RATE_LIMIT_ID_SALT=
